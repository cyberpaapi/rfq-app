# Copy to .env and fill in. Never commit your real .env.
OPENAI_API_KEY=sk-your-key-here

# Models
OPENAI_MODEL=gpt-5.4-mini       # per-page / per-row extraction
OPENAI_CLUB_MODEL=gpt-5.5       # "clubbed view" consolidation pass

# Parallel pipeline tuning (optional)
# AI_CONCURRENCY=4              # chunks processed at once
# AI_PAGES_PER_CALL=1          # PDF pages per request
# AI_ROWS_PER_CALL=10          # spreadsheet rows per request
# AI_MAX_TOKENS=8000

# Server
# PORT=4000
